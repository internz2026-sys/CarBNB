# CarBNB env var reference.
# Copy to .env.local for development. Values below are placeholders — replace with real ones.
# Production values live in Vercel dashboard (Project → Settings → Environment Variables).

# ─────────────────────────────────────────────────────────────
# Database (Postgres)
# ─────────────────────────────────────────────────────────────
# Local dev: Docker Postgres on host port 5433 (native Windows pg holds 5432).
# Production: Supabase pooled URL for DATABASE_URL, session-mode URL for DIRECT_URL.
#   Pooled   → aws-1-<region>.pooler.supabase.com:6543  (?pgbouncer=true)
#   Direct   → aws-1-<region>.pooler.supabase.com:5432

DATABASE_URL="postgresql://postgres:password123@localhost:5433/carbnb_admin?schema=public"
DIRECT_URL="postgresql://postgres:password123@localhost:5433/carbnb_admin?schema=public"

# ─────────────────────────────────────────────────────────────
# Supabase (Auth + Storage — shared across dev and prod)
# ─────────────────────────────────────────────────────────────
# Get from Supabase dashboard → Project Settings → API.
# NEXT_PUBLIC_* vars are exposed to the browser — safe (anon key is rate-limited and RLS-gated).
# SERVICE_ROLE_KEY is server-only. Never import into client components.

NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-jwt>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret>"
