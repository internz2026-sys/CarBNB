generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User / Admin
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Owners
model Owner {
  id                 String   @id @default(cuid())
  fullName           String
  contactNumber      String
  email              String   @unique
  address            String
  status             String   @default("PENDING") // VERIFIED, PENDING, SUSPENDED
  remarks            String?
  bankDetails        String?
  idDocumentUrl      String?
  licenseDocumentUrl String?
  carsCount          Int      @default(0)
  totalEarnings      Float    @default(0)
  bio                String?  // public-profile bio, max 500 chars (validated in Zod)

  // Tier 15 — host kind discriminator. INDIVIDUAL = a person who owns a car
  // and manages it themselves (existing behavior). FLEET = a registered
  // car rental company that can manage bookings on behalf of one or many
  // independent owners via FleetCarLink. Locked at signup; admin can flip
  // manually if a host requests a change.
  kind               String   @default("INDIVIDUAL") // INDIVIDUAL | FLEET
  companyName        String?  // only meaningful when kind=FLEET
  businessRegNumber  String?  // only meaningful when kind=FLEET
  serviceArea        String?  // public service-area / city of operations (FLEET-only).
                              // Different concern from Owner.address (which is private,
                              // used for ID verification). Helps independent owners
                              // pick a fleet near them when requesting management.

  // Tier 19 — fleet legitimacy doc. Required for FLEET hosts before admin
  // can verify (DTI / SEC / similar PH business registration certificate).
  // Null for INDIVIDUAL kind. Stored in private `owner-documents` bucket.
  businessRegistrationDocumentUrl String?

  // Tier 21 — fleet primary location (manually pinned on a Leaflet map at
  // signup or via /host/profile). Null until the fleet sets it. Used by:
  //   - /fleets directory: render pins on the public map
  //   - /host/cars/[id]/edit fleet picker: render pins for selection
  // INDIVIDUAL kind ignores these fields. No geocoding service involved —
  // the fleet drops a pin manually, we store lat/lng as-is.
  latitude    Float?
  longitude   Float?

  cars            CarListing[]
  bookings        Booking[]
  ownerPayouts    OwnerPayout[]
  reviews         Review[]
  managedLinks    FleetCarLink[] @relation("FleetManagedLinks")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CarListing {
  id                  String   @id @default(cuid())
  ownerId             String
  owner               Owner    @relation(fields: [ownerId], references: [id])
  plateNumber         String   @unique
  brand               String
  model               String
  year                Int
  color               String
  transmission        String   // AUTOMATIC, MANUAL
  fuelType            String   // GASOLINE, DIESEL, ELECTRIC, HYBRID
  vehicleType         String   @default("SEDAN") // SEDAN, SUV, HATCHBACK, MPV, VAN, PICKUP, COUPE
  features            String[] @default([])      // slugs from VEHICLE_FEATURES (lib/listing-taxonomy.ts)
  seatingCapacity     Int
  location            String
  dailyPrice          Float
  description         String?
  photos              String[]
  orCrDocumentUrl     String?
  status              String   @default("PENDING_APPROVAL") // ACTIVE, INACTIVE, MAINTENANCE, BOOKED, PENDING_APPROVAL
  availabilitySummary String?
  notes               String?
  avgRating           Float    @default(0)        // recomputed on every review insert (Tier 10)
  reviewCount         Int      @default(0)        // recomputed on every review insert (Tier 10)

  bookings            Booking[]
  availabilityRules   CarAvailabilityRule[]
  exceptions          CarAvailabilityException[]
  reviews             Review[]
  favorites           Favorite[]
  fleetLinks          FleetCarLink[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  fullName      String
  contactNumber String
  email         String   @unique
  address       String?
  totalBookings Int      @default(0)

  // Tier 19 — identity verification. New customers default to PENDING; the
  // migration backfilled all pre-existing rows to VERIFIED (grandfathering
  // decision in BACKLOG.md). Booking creation is server-side gated on
  // status = VERIFIED. Admin reviews documents and flips PENDING → VERIFIED
  // or REJECTED on the per-customer admin page.
  status              String  @default("PENDING") // VERIFIED, PENDING, SUSPENDED, REJECTED
  idDocumentUrl       String? // private `customer-documents` bucket
  licenseDocumentUrl  String? // private `customer-documents` bucket

  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  customerName    String
  
  carListingId    String
  carListing      CarListing @relation(fields: [carListingId], references: [id])
  carName         String
  carPhoto        String?
  plateNumber     String
  seatingCapacity Int
  
  ownerId         String
  owner           Owner    @relation(fields: [ownerId], references: [id])
  ownerName       String
  
  pickupDate      DateTime
  returnDate      DateTime
  
  totalAmount     Float
  platformFee     Float
  ownerPayout     Float
  
  status          String   @default("PENDING") // PENDING, CONFIRMED, ONGOING, COMPLETED, CANCELLED, REJECTED
  paymentStatus   String   @default("UNPAID")  // UNPAID, PARTIALLY_PAID, PAID, REFUNDED

  // Payment capture fields (Tier 5, cash-only model for now)
  paymentMethod    String?   // "CASH" today; extensible for GCash/bank later
  paymentReceivedAt DateTime?
  paymentReceivedBy String?  // admin email who marked it paid
  paymentProofUrl   String?  // optional receipt photo (no UI yet)
  paymentNotes      String?

  // Cancellation / rejection capture fields (Tier 5)
  cancellationReason String?  // preset slug: customer_no_show | documents_not_verified | vehicle_unavailable | duplicate_booking | other
  cancellationNote   String?  // required when reason is "other", optional otherwise
  cancelledAt        DateTime?
  cancelledBy        String?  // admin email or "customer" if self-cancelled

  // Timestamps for start / completion of the rental
  rentalStartedAt    DateTime?
  rentalCompletedAt  DateTime?

  accountingEntries AccountingEntry[]
  review            Review?
  messages          Message[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CarAvailabilityRule {
  id           String     @id @default(cuid())
  carListingId String
  carListing   CarListing @relation(fields: [carListingId], references: [id])
  dayOfWeek    String     // MONDAY, TUESDAY...
  isAvailable  Boolean    @default(true)
  startTime    String?    // e.g., "08:00"
  endTime      String?    // e.g., "18:00"

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CarAvailabilityException {
  id           String     @id @default(cuid())
  carListingId String
  carListing   CarListing @relation(fields: [carListingId], references: [id])
  date         DateTime
  isAvailable  Boolean    @default(false)
  reason       String?

  // Tier 16 — audit trail for who created the exception. Null for rows
  // migrated from Tier 7 era (we only learn the author for new writes).
  // Read-side UI shows "blocked by Joe" or "blocked by Acme Rentals" when
  // present so the individual + fleet can tell who scheduled what.
  addedByOwnerId String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AccountingEntry {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  bookingRef    String
  customerName  String
  carName       String
  ownerName     String
  
  bookingAmount Float
  platformFee   Float
  ownerPayout   Float
  
  paymentStatus String
  payoutStatus  String   // PENDING, PROCESSING, RELEASED, FAILED
  date          DateTime
  transactionType String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OwnerPayout {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              Owner    @relation(fields: [ownerId], references: [id])
  ownerName          String
  totalEarnings      Float
  platformCommission Float
  netPayout          Float
  payoutMethod       String
  payoutStatus       String
  dateReleased       DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ActivityLogEntry {
  id          String   @id @default(cuid())
  action      String
  description String
  type        String   // system, owner, car, booking
  timestamp   DateTime @default(now())
}

// Customer reviews — Tier 10. One per booking (enforced via unique on bookingId).
// Customer-only at write time; aggregates (avgRating, reviewCount) are denormalized
// onto CarListing and recomputed on every insert.
model Review {
  id         String   @id @default(cuid())

  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  listingId  String
  listing    CarListing @relation(fields: [listingId], references: [id])

  ownerId    String
  owner      Owner    @relation(fields: [ownerId], references: [id])

  rating     Int      // 1-5, validated in app
  comment    String?  // up to 1000 chars (validated in Zod)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([listingId, createdAt(sort: Desc)])
  @@index([customerId])
}

// Fleet-car links — Tier 15. Independent owner requests management of
// their car by a fleet operator. Lifecycle:
//   - PENDING: owner sent request; fleet hasn't responded
//   - ACTIVE:  fleet approved; the link is operational. Tier 16 will
//              route bookings + chat through the fleet on these cars.
//              Tier 15 only renders "managed by X" labels.
//   - INACTIVE: link severed by either side, or fleet rejected the
//              request. Historical row preserved for audit.
//
// The constraint "one ACTIVE link per listing" is enforced at the
// application layer (in approveLinkAction) — Prisma doesn't support
// partial unique indexes via the schema language, and a full unique on
// (listingId, status) would prevent multiple INACTIVE/PENDING rows
// over time which is fine to allow.
model FleetCarLink {
  id                    String   @id @default(cuid())

  listingId             String
  listing               CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  fleetId               String
  fleet                 Owner    @relation("FleetManagedLinks", fields: [fleetId], references: [id], onDelete: Cascade)

  status                String   // PENDING | ACTIVE | INACTIVE
  managementFeePercent  Float?   // captured at link approval; deduction defers to Tier 8 (accounting)

  requestedAt           DateTime @default(now())
  respondedAt           DateTime?
  severedAt             DateTime?

  @@index([fleetId, status])
  @@index([listingId, status])
}

// Booking chat messages — Tier 14. Per-booking lifecycle-bounded chat.
// `kind = "user"` rows have senderRole "customer" or "host" + senderId.
// `kind = "system"` rows are auto-injected on status transitions and have
// senderRole "system" + senderId null. Cascade-deletes with Booking so a
// booking removal doesn't leave orphan messages.
model Message {
  id          String   @id @default(cuid())

  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  kind        String   // "user" | "system"
  senderRole  String   // "customer" | "host" | "system"
  senderId    String?  // Customer.id or Owner.id; null for system messages

  body        String   // up to 1000 chars (validated in Zod)

  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt])
}

// Customer favorites — Tier 11. Login-required save. Unique per
// (customer, listing) pair so the toggle is idempotent at the DB layer.
model Favorite {
  id         String   @id @default(cuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  listingId  String
  listing    CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([customerId, listingId])
  @@index([customerId, createdAt(sort: Desc)])
}

// Single-row settings table. Always queried/mutated by the literal id
// "singleton"; helper in lib/platform-settings.ts upserts on read so the
// row is self-healing if something wipes it.
model PlatformSettings {
  id                           String   @id @default("singleton")
  commissionRate               Float    @default(0.15)    // 0-1, fraction of booking total
  securityDeposit              Float    @default(5000)    // PHP
  autoApproveVerifiedCustomers Boolean  @default(false)
  requireOwnerConfirmation     Boolean  @default(false)
  minimumBookingNoticeHours    Int      @default(24)

  updatedAt                    DateTime @updatedAt
  updatedBy                    String?  // admin email who last saved
}

// Tier 20 — notifications. Drives the in-app bell + /notifications archive
// page. Always created alongside an outbound email by lib/notify.ts; the
// in-app and email surfaces share the same trigger points and payload.
// Indexed on (recipientEmail, isRead, createdAt) for the bell-icon query
// which fetches unread count + 5 most recent per logged-in user.
model Notification {
  id              String    @id @default(cuid())
  recipientEmail  String                                          // who this is for; matched against Supabase auth.users.email
  recipientRole   String                                          // "admin" | "host" | "customer" — drives which archive page / bell renders
  type            String                                          // BOOKING_CREATED, CUSTOMER_VERIFIED, etc. — see notification-types in lib/notify.ts
  title           String                                          // short headline shown in the bell dropdown
  body            String                                          // 1-2 sentence preview, also used as email subject body
  linkUrl         String?                                         // optional — click navigates here (e.g. /host/bookings/[id])
  isRead          Boolean   @default(false)
  readAt          DateTime?                                       // set when the user clicks the notification (or "Mark all as read")
  createdAt       DateTime  @default(now())

  @@index([recipientEmail, isRead, createdAt])
  @@index([recipientEmail, createdAt])
}
