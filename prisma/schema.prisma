generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User / Admin
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Owners
model Owner {
  id                 String   @id @default(cuid())
  fullName           String
  contactNumber      String
  email              String   @unique
  address            String
  status             String   @default("PENDING") // VERIFIED, PENDING, SUSPENDED
  remarks            String?
  bankDetails        String?
  idDocumentUrl      String?
  licenseDocumentUrl String?
  carsCount          Int      @default(0)
  totalEarnings      Float    @default(0)
  bio                String?  // public-profile bio, max 500 chars (validated in Zod)

  cars          CarListing[]
  bookings      Booking[]
  ownerPayouts  OwnerPayout[]
  reviews       Review[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CarListing {
  id                  String   @id @default(cuid())
  ownerId             String
  owner               Owner    @relation(fields: [ownerId], references: [id])
  plateNumber         String   @unique
  brand               String
  model               String
  year                Int
  color               String
  transmission        String   // AUTOMATIC, MANUAL
  fuelType            String   // GASOLINE, DIESEL, ELECTRIC, HYBRID
  vehicleType         String   @default("SEDAN") // SEDAN, SUV, HATCHBACK, MPV, VAN, PICKUP, COUPE
  features            String[] @default([])      // slugs from VEHICLE_FEATURES (lib/listing-taxonomy.ts)
  seatingCapacity     Int
  location            String
  dailyPrice          Float
  description         String?
  photos              String[]
  orCrDocumentUrl     String?
  status              String   @default("PENDING_APPROVAL") // ACTIVE, INACTIVE, MAINTENANCE, BOOKED, PENDING_APPROVAL
  availabilitySummary String?
  notes               String?
  avgRating           Float    @default(0)        // recomputed on every review insert (Tier 10)
  reviewCount         Int      @default(0)        // recomputed on every review insert (Tier 10)

  bookings            Booking[]
  availabilityRules   CarAvailabilityRule[]
  exceptions          CarAvailabilityException[]
  reviews             Review[]
  favorites           Favorite[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Customer {
  id            String   @id @default(cuid())
  fullName      String
  contactNumber String
  email         String   @unique
  address       String?
  totalBookings Int      @default(0)

  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  customerName    String
  
  carListingId    String
  carListing      CarListing @relation(fields: [carListingId], references: [id])
  carName         String
  carPhoto        String?
  plateNumber     String
  seatingCapacity Int
  
  ownerId         String
  owner           Owner    @relation(fields: [ownerId], references: [id])
  ownerName       String
  
  pickupDate      DateTime
  returnDate      DateTime
  
  totalAmount     Float
  platformFee     Float
  ownerPayout     Float
  
  status          String   @default("PENDING") // PENDING, CONFIRMED, ONGOING, COMPLETED, CANCELLED, REJECTED
  paymentStatus   String   @default("UNPAID")  // UNPAID, PARTIALLY_PAID, PAID, REFUNDED

  // Payment capture fields (Tier 5, cash-only model for now)
  paymentMethod    String?   // "CASH" today; extensible for GCash/bank later
  paymentReceivedAt DateTime?
  paymentReceivedBy String?  // admin email who marked it paid
  paymentProofUrl   String?  // optional receipt photo (no UI yet)
  paymentNotes      String?

  // Cancellation / rejection capture fields (Tier 5)
  cancellationReason String?  // preset slug: customer_no_show | documents_not_verified | vehicle_unavailable | duplicate_booking | other
  cancellationNote   String?  // required when reason is "other", optional otherwise
  cancelledAt        DateTime?
  cancelledBy        String?  // admin email or "customer" if self-cancelled

  // Timestamps for start / completion of the rental
  rentalStartedAt    DateTime?
  rentalCompletedAt  DateTime?

  accountingEntries AccountingEntry[]
  review            Review?
  messages          Message[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CarAvailabilityRule {
  id           String     @id @default(cuid())
  carListingId String
  carListing   CarListing @relation(fields: [carListingId], references: [id])
  dayOfWeek    String     // MONDAY, TUESDAY...
  isAvailable  Boolean    @default(true)
  startTime    String?    // e.g., "08:00"
  endTime      String?    // e.g., "18:00"

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CarAvailabilityException {
  id           String     @id @default(cuid())
  carListingId String
  carListing   CarListing @relation(fields: [carListingId], references: [id])
  date         DateTime
  isAvailable  Boolean    @default(false)
  reason       String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AccountingEntry {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  bookingRef    String
  customerName  String
  carName       String
  ownerName     String
  
  bookingAmount Float
  platformFee   Float
  ownerPayout   Float
  
  paymentStatus String
  payoutStatus  String   // PENDING, PROCESSING, RELEASED, FAILED
  date          DateTime
  transactionType String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OwnerPayout {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              Owner    @relation(fields: [ownerId], references: [id])
  ownerName          String
  totalEarnings      Float
  platformCommission Float
  netPayout          Float
  payoutMethod       String
  payoutStatus       String
  dateReleased       DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ActivityLogEntry {
  id          String   @id @default(cuid())
  action      String
  description String
  type        String   // system, owner, car, booking
  timestamp   DateTime @default(now())
}

// Customer reviews — Tier 10. One per booking (enforced via unique on bookingId).
// Customer-only at write time; aggregates (avgRating, reviewCount) are denormalized
// onto CarListing and recomputed on every insert.
model Review {
  id         String   @id @default(cuid())

  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  listingId  String
  listing    CarListing @relation(fields: [listingId], references: [id])

  ownerId    String
  owner      Owner    @relation(fields: [ownerId], references: [id])

  rating     Int      // 1-5, validated in app
  comment    String?  // up to 1000 chars (validated in Zod)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([listingId, createdAt(sort: Desc)])
  @@index([customerId])
}

// Booking chat messages — Tier 14. Per-booking lifecycle-bounded chat.
// `kind = "user"` rows have senderRole "customer" or "host" + senderId.
// `kind = "system"` rows are auto-injected on status transitions and have
// senderRole "system" + senderId null. Cascade-deletes with Booking so a
// booking removal doesn't leave orphan messages.
model Message {
  id          String   @id @default(cuid())

  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  kind        String   // "user" | "system"
  senderRole  String   // "customer" | "host" | "system"
  senderId    String?  // Customer.id or Owner.id; null for system messages

  body        String   // up to 1000 chars (validated in Zod)

  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt])
}

// Customer favorites — Tier 11. Login-required save. Unique per
// (customer, listing) pair so the toggle is idempotent at the DB layer.
model Favorite {
  id         String   @id @default(cuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  listingId  String
  listing    CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([customerId, listingId])
  @@index([customerId, createdAt(sort: Desc)])
}

// Single-row settings table. Always queried/mutated by the literal id
// "singleton"; helper in lib/platform-settings.ts upserts on read so the
// row is self-healing if something wipes it.
model PlatformSettings {
  id                           String   @id @default("singleton")
  commissionRate               Float    @default(0.15)    // 0-1, fraction of booking total
  securityDeposit              Float    @default(5000)    // PHP
  autoApproveVerifiedCustomers Boolean  @default(false)
  requireOwnerConfirmation     Boolean  @default(false)
  minimumBookingNoticeHours    Int      @default(24)

  updatedAt                    DateTime @updatedAt
  updatedBy                    String?  // admin email who last saved
}
